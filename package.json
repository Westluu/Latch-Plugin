{
  "name": "latch-inline-review",
  "displayName": "Latch Inline Review",
  "description": "Inline git-diff review for proposed edits in VS Code.",
  "version": "0.0.1",
  "publisher": "wesleyluu",
  "engines": {
    "vscode": "^1.91.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onView:latch.reviewSidebar",
    "onCommand:latch.reviewActiveFileGitDiff",
    "onCommand:latch.acceptDiff",
    "onCommand:latch.rejectDiff",
    "onCommand:latch.acceptAllDiffs",
    "onCommand:latch.rejectAllDiffs",
    "onCommand:latch.previewInlineDiff"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "latch-sidebar",
          "title": "Latch",
          "icon": "res/latch-icon.svg"
        }
      ]
    },
    "commands": [
      {
        "command": "latch.reviewActiveFileGitDiff",
        "title": "Review Active File Git Diff",
        "category": "Latch"
      },
      {
        "command": "latch.acceptDiff",
        "title": "Accept Inline Diff",
        "category": "Latch"
      },
      {
        "command": "latch.rejectDiff",
        "title": "Reject Inline Diff",
        "category": "Latch"
      },
      {
        "command": "latch.acceptAllDiffs",
        "title": "Accept All Inline Diffs",
        "category": "Latch"
      },
      {
        "command": "latch.rejectAllDiffs",
        "title": "Reject All Inline Diffs",
        "category": "Latch"
      },
      {
        "command": "latch.previewInlineDiff",
        "title": "Preview Inline Diff",
        "category": "Latch"
      }
    ],
    "views": {
      "latch-sidebar": [
        {
          "id": "latch.reviewSidebar",
          "name": "Latch Reviews"
        }
      ]
    },
    "menus": {
      "editor/context": [
        {
          "command": "latch.reviewActiveFileGitDiff",
          "when": "editorTextFocus",
          "group": "1_modification"
        }
      ],
      "editor/title": [
        {
          "command": "latch.reviewActiveFileGitDiff",
          "when": "editorTextFocus",
          "group": "navigation@100"
        }
      ],
      "commandPalette": [
        {
          "command": "latch.reviewActiveFileGitDiff",
          "when": "editorTextFocus"
        },
        {
          "command": "latch.acceptDiff",
          "when": "latch.hasActiveInlineReview"
        },
        {
          "command": "latch.rejectDiff",
          "when": "latch.hasActiveInlineReview"
        },
        {
          "command": "latch.acceptAllDiffs",
          "when": "latch.hasActiveInlineReview"
        },
        {
          "command": "latch.rejectAllDiffs",
          "when": "latch.hasActiveInlineReview"
        },
        {
          "command": "latch.previewInlineDiff",
          "when": "latch.hasActiveInlineReview"
        }
      ]
    },
    "keybindings": [
      {
        "command": "latch.acceptDiff",
        "key": "ctrl+y",
        "mac": "cmd+y",
        "when": "editorTextFocus && latch.hasActiveInlineReview"
      },
      {
        "command": "latch.rejectDiff",
        "key": "ctrl+n",
        "mac": "cmd+n",
        "when": "editorTextFocus && latch.hasActiveInlineReview"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/vscode": "^1.91.0",
    "typescript": "^5.7.2"
  }
}
