{
  "name": "latch-inline-review",
  "displayName": "Latch Inline Review",
  "description": "Continue-style inline diff review for proposed edits in VS Code.",
  "version": "0.0.1",
  "publisher": "wesleyluu",
  "engines": {
    "vscode": "^1.91.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:latch.reviewSelectionFromClipboard",
    "onCommand:latch.acceptDiff",
    "onCommand:latch.rejectDiff",
    "onCommand:latch.acceptAllDiffs",
    "onCommand:latch.rejectAllDiffs",
    "onCommand:latch.previewInlineDiff"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "latch.reviewSelectionFromClipboard",
        "title": "Review Selection From Clipboard",
        "category": "Latch"
      },
      {
        "command": "latch.acceptDiff",
        "title": "Accept Inline Diff",
        "category": "Latch"
      },
      {
        "command": "latch.rejectDiff",
        "title": "Reject Inline Diff",
        "category": "Latch"
      },
      {
        "command": "latch.acceptAllDiffs",
        "title": "Accept All Inline Diffs",
        "category": "Latch"
      },
      {
        "command": "latch.rejectAllDiffs",
        "title": "Reject All Inline Diffs",
        "category": "Latch"
      },
      {
        "command": "latch.previewInlineDiff",
        "title": "Preview Inline Diff",
        "category": "Latch"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "latch.reviewSelectionFromClipboard",
          "when": "editorTextFocus && editorHasSelection",
          "group": "1_modification"
        }
      ],
      "commandPalette": [
        {
          "command": "latch.reviewSelectionFromClipboard",
          "when": "editorTextFocus && editorHasSelection"
        },
        {
          "command": "latch.acceptDiff",
          "when": "latch.hasActiveInlineReview"
        },
        {
          "command": "latch.rejectDiff",
          "when": "latch.hasActiveInlineReview"
        },
        {
          "command": "latch.acceptAllDiffs",
          "when": "latch.hasActiveInlineReview"
        },
        {
          "command": "latch.rejectAllDiffs",
          "when": "latch.hasActiveInlineReview"
        },
        {
          "command": "latch.previewInlineDiff",
          "when": "latch.hasActiveInlineReview"
        }
      ]
    },
    "keybindings": [
      {
        "command": "latch.acceptDiff",
        "key": "ctrl+y",
        "mac": "cmd+y",
        "when": "editorTextFocus && latch.hasActiveInlineReview"
      },
      {
        "command": "latch.rejectDiff",
        "key": "ctrl+n",
        "mac": "cmd+n",
        "when": "editorTextFocus && latch.hasActiveInlineReview"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "dependencies": {
    "diff": "^7.0.0"
  },
  "devDependencies": {
    "@types/diff": "^7.0.1",
    "@types/node": "^22.10.5",
    "@types/vscode": "^1.91.0",
    "typescript": "^5.7.2"
  }
}
